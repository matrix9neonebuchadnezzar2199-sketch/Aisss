# AISSS stack environment template.
# Copy to aisss/.env and set real values. Never commit aisss/.env.

# Published ports on the host
AISSS_WEB_PORT=3000
AISSS_API_PORT=8000
AISSS_MINIO_API_PORT=9000
AISSS_MINIO_CONSOLE_PORT=9001
AISSS_VECTOR_PORT=6333

# PostgreSQL
AISSS_DB_USER=aisss
AISSS_DB_PASSWORD=change-me
AISSS_DB_NAME=aisss
DATABASE_URL=postgresql://aisss:change-me@db:5432/aisss

# Object storage (MinIO)
AISSS_MINIO_ROOT_USER=aisss
AISSS_MINIO_ROOT_PASSWORD=change-me
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_BUCKET=aisss
OBJECT_STORAGE_ACCESS_KEY=aisss
OBJECT_STORAGE_SECRET_KEY=change-me

# Queue
REDIS_URL=redis://redis:6379/0

# Vector DB
VECTOR_DB_URL=http://vector:6333

# Ollama (host — not in Compose)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_HEALTH_INTERVAL_SEC=30

# Auth provider placeholder until SSO is selected
AUTH_PROVIDER=placeholder

# API runtime
API_PORT=8000
API_MIGRATE_ON_START=true
MIGRATIONS_DIR=/infra/migrations
